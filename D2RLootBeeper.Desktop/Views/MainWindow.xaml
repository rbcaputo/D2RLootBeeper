<Window
    x:Class="D2RLootBeeper.Desktop.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="D2R Loot Beeper"
    Width="900"
    Height="700">

  <Grid Margin="20">

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="20"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->

    <StackPanel>

      <TextBlock
                FontSize="24"
                FontWeight="Bold"
                Text="D2R Loot Beeper"/>

      <TextBlock
                Margin="0,8,0,0"
                FontSize="14">

                <Run Text="Game Status: "/>

                <Run
                    Text="{Binding IsGameRunning}" />

      </TextBlock>

    </StackPanel>

    <!-- Categories -->

    <ScrollViewer
            Grid.Row="2"
            VerticalScrollBarVisibility="Auto">

      <ItemsControl
                ItemsSource="{Binding Categories}">

        <ItemsControl.ItemTemplate>

          <DataTemplate>

            <StackPanel Margin="0,0,0,20">

              <TextBlock
                                FontSize="18"
                                FontWeight="Bold"
                                Text="{Binding Name}" />

              <ItemsControl
                                ItemsSource="{Binding Items}">

                <ItemsControl.ItemTemplate>

                  <DataTemplate>

                    <CheckBox
                                            Margin="20,4,0,0"
                                            IsChecked="{Binding IsSelected}"
                                            Content="{Binding Name}" />

                  </DataTemplate>

                </ItemsControl.ItemTemplate>

              </ItemsControl>

            </StackPanel>

          </DataTemplate>

        </ItemsControl.ItemTemplate>

      </ItemsControl>

    </ScrollViewer>

  </Grid>

</Window>